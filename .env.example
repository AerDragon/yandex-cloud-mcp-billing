# --- Auth (pick ONE) ---
# 1) Static IAM token (12h TTL, easiest for local dev):
#    yc iam create-token
# YC_IAM_TOKEN=t1.9eu...

# 2) Service account key file (recommended for servers):
#    yc iam key create --service-account-name <sa> --output key.json
# YC_SA_KEY_FILE=/path/to/key.json
# YC_SA_KEY_JSON='{"id":"...","service_account_id":"...","private_key":"-----BEGIN ..."}'

# 3) OAuth token from https://oauth.yandex.com/authorize?response_type=token&client_id=1a6990aa636648e9b2ef855fa7bec2fb
# YC_OAUTH_TOKEN=y0_...

# 4) Workload Identity Federation (running inside Kubernetes):
#    mount a projected service account token and point to it.
# YC_WORKLOAD_TOKEN_FILE=/var/run/secrets/tokens/yc-token
# YC_WORKLOAD_AUDIENCE=https://iam.api.cloud.yandex.net  # set if your federation requires it

# 5) YC Compute / Managed K8s instance metadata service:
# YC_USE_METADATA=true

# --- Defaults ---
YC_DEFAULT_CURRENCY=RUB

# Display currency (auto-conversion of every price / balance / spend response).
# Can be any 3-letter code published by the Central Bank of Russia daily feed
# (USD, EUR, RUB, KZT, CNY, GBP, JPY, …). LLMs may switch it at runtime via the
# set_display_currency tool; this value is just the initial default.
YC_DISPLAY_CURRENCY=USD

# Cache TTL (seconds) for ConsumptionCore gRPC API responses. The API is rate
# limited to ~1 request per minute per IP, so cache aggressively.
YC_USAGE_CACHE_TTL=300

# FX rates source + cache. Defaults to CBR's free daily feed; you can point at
# any URL with the same JSON shape.
FX_RATES_URL=https://www.cbr-xml-daily.ru/daily_json.js
FX_CACHE_TTL=21600

# --- MCP server ---
MCP_TRANSPORT=streamable-http  # streamable-http | sse | stdio
MCP_HOST=127.0.0.1             # use 0.0.0.0 inside containers
MCP_PORT=8000
MCP_PATH=/mcp

LOG_LEVEL=INFO
